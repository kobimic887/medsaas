# Core server
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# Branding (company name comes from signup; these are fallbacks only)
PLATFORM_NAME=MedSaaS
PLATFORM_WEBSITE_URL=http://localhost:5173
JWT_SECRET=replace-with-a-long-random-secret
# Session token lifetime (jsonwebtoken `expiresIn` format, e.g. 12h, 7d, 30d). Optional; defaults to 7d.
JWT_EXPIRES_IN=7d

# MongoDB
MONGODB_URI=mongodb://localhost:27017/medsaas
# For the containerized deploy (mongo runs as a compose service), use instead:
#   MONGODB_URI=mongodb://root:<MONGO_PASSWORD>@mongo:27017/medsaas?authSource=admin
# and set the mongo container root credentials:
MONGO_USER=root
MONGO_PASSWORD=change-me

# Stripe
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Frontend build-time config
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
VITE_PLATFORM_NAME=MedSaaS
# Leave empty for local dev — Vite proxies /api and other backend paths to port 3000
# VITE_API_BASE_URL=

# Email via Titan Mail
EMAIL_USER=notifications@example.com
EMAIL_PASS=replace-with-mail-password

# NVIDIA APIs
NVIDIA_MOLMIM_API_KEY=replace-me
NVIDIA_OPENFOLD_API_KEY=replace-me

# External scientific services
TANIMOTO_API_BASE=http://151.145.91.17:8000
# Ligand catalog/stock/docking endpoints. These seed the DEFAULT ligand service
# config; each company can override them in Company Admin (stored on the company record).
ASINEX_API_BASE=http://dev.asinex.com:58181
ASINEX_STOCK_API_URL=https://stock.asinex.com:5443/api/Shop
ASINEX_DOCKING_API_URL=https://services.asinex.com:8000/docking
DIFFDOCK_API_URL=https://services.asinex.com:58000/molecular-docking/diffdock/generate
SDF_CONVERTER_URL=http://83.229.87.94:8001/convertSTR

# RabbitMQ / ADMET worker integration
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
ADMET_QUEUE_NAME=admet_processing_queue
ADMET_CALLBACK_SECRET=replace-with-shared-worker-secret

# Integrated scientific microservices (docker compose --profile science)
GROMACS_API_BASE=http://localhost:8001
GLIOBLASTOMA_API_BASE=http://localhost:5000

# Optional HTTPS serving
# SSL_KEY_PATH=/path/to/key.pem
# SSL_CERT_PATH=/path/to/cert.pem
